<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Zambia Smart School Placement System</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
}

body{
background:#f4f9ff;
}

/* HEADER */
header{
background:linear-gradient(90deg,green,blue);
color:white;
text-align:center;
padding:40px;
}

/* NAV */
nav{
background:#003366;
padding:15px;
text-align:center;
}

nav a{
color:white;
margin:15px;
text-decoration:none;
font-weight:bold;
cursor:pointer;
}

/* SECTIONS */
.section{
display:none;
padding:20px;
}

.active{
display:block;
}

/* SCHOOL LIST */
.school-list{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
margin-top:20px;
}

.school-card{
background:white;
padding:15px;
border-radius:10px;
box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

.apply-btn{
margin-top:10px;
padding:10px;
background:orange;
color:white;
border:none;
cursor:pointer;
width:100%;
}

/* FORM */
input,select{
width:100%;
padding:12px;
margin:10px 0;
border:1px solid #ccc;
border-radius:5px;
}

button{
padding:12px;
background:green;
color:white;
border:none;
cursor:pointer;
width:100%;
}

/* ADMIN PANEL */
.admin-box{
max-width:500px;
margin:auto;
}

.admin-school{
background:white;
padding:10px;
margin:10px 0;
border-radius:5px;
box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

.delete-btn{
background:red;
color:white;
padding:8px;
border:none;
cursor:pointer;
width:100%;
margin-top:5px;
}

.logout-btn{
background:black;
color:white;
margin-top:10px;
}

</style>

</head>

<body>

<!-- HEADER -->
<header>
<h1>Welcome to Zambia Smart School Placement System</h1>
<p>Designed by Romario Chiyesu William</p>
<p>📞 0968246760</p>
</header>

<!-- NAV -->
<nav>
<a onclick="show('home')">Home</a>
<a onclick="show('apply')">Apply</a>
<a onclick="show('admin')">Admin</a>
</nav>

<!-- HOME -->
<div id="home" class="section active">

<h2>Available Schools</h2>

<div class="school-list" id="schoolList"></div>

</div>

<!-- APPLY -->
<div id="apply" class="section">

<h2>Application Form</h2>

<form id="applicationForm">

<input type="text" id="name" placeholder="Full Name" required>
<input type="email" id="email" placeholder="Email" required>
<input type="text" id="examNumber" placeholder="Exam Number" required>
<input type="number" id="examYear" placeholder="Exam Year" required>
<input type="text" id="fromSchool" placeholder="School Coming From" required>

<input type="text" id="selectedSchool" placeholder="Selected School" readonly>

<select id="grade" required>
<option>Grade 8</option>
<option>Grade 9</option>
<option>Grade 10</option>
<option>Grade 11</option>
<option>Grade 12</option>
</select>

<button type="submit">Submit Application</button>

</form>

</div>

<!-- ADMIN -->
<div id="admin" class="section">

<div class="admin-box">

<h2>Admin Login</h2>

<input type="password" id="password" placeholder="Enter Password">
<button onclick="login()">Login</button>

<p id="msg"></p>

<div id="panel" style="display:none; margin-top:20px;">

<h3>Add School</h3>

<input type="text" id="newName" placeholder="School Name">
<input type="text" id="newLocation" placeholder="Location">
<input type="number" id="newPlaces" placeholder="Places">

<button onclick="addSchool()">Add School</button>

<h3 style="margin-top:20px;">Manage Schools</h3>

<div id="adminList"></div>

<!-- LOGOUT BUTTON -->
<button class="logout-btn" onclick="logout()">
Logout
</button>

</div>

</div>

</div>

<script>

/* PAGE SWITCH */
function show(id){

document.querySelectorAll('.section').forEach(s=>{
s.classList.remove('active');
});

document.getElementById(id).classList.add('active');

}

/* SCHOOL DATA */
let schools = [
{name:"Solwezi Secondary School", location:"Solwezi", places:3},
{name:"Lusaka High School", location:"Lusaka", places:5},
{name:"Ndola Girls School", location:"Ndola", places:2}
];

/* LOAD HOME SCHOOLS */
function loadSchools(){

let box = document.getElementById("schoolList");

box.innerHTML = "";

schools.forEach((s,index)=>{

box.innerHTML += `
<div class="school-card">
<h3>${s.name}</h3>
<p>📍 ${s.location}</p>
<p>🏫 Places: ${s.places}</p>

<button class="apply-btn" onclick="selectSchool('${s.name}')">
Apply
</button>

</div>
`;

});

}

/* SELECT SCHOOL */
function selectSchool(name){

document.getElementById("selectedSchool").value = name;

show('apply');

}

/* SUBMIT FORM */
document.getElementById("applicationForm").addEventListener("submit",function(e){

e.preventDefault();

alert("Application Submitted Successfully!");

this.reset();

});

/* LOGIN */
function login(){

let pass = document.getElementById("password").value;

if(pass === "12345"){
document.getElementById("msg").innerHTML = "Login successful!";
document.getElementById("msg").style.color = "green";

document.getElementById("panel").style.display = "block";

loadAdmin();

}else{
document.getElementById("msg").innerHTML = "Wrong password!";
document.getElementById("msg").style.color = "red";
}

}

/* ADD SCHOOL */
function addSchool(){

let name = document.getElementById("newName").value;
let location = document.getElementById("newLocation").value;
let places = document.getElementById("newPlaces").value;

schools.push({
name:name,
location:location,
places:places
});

loadSchools();
loadAdmin();

alert("School added!");

}

/* ADMIN LIST */
function loadAdmin(){

let box = document.getElementById("adminList");

box.innerHTML = "";

schools.forEach((s,index)=>{

box.innerHTML += `
<div class="admin-school">
<h4>${s.name}</h4>
<p>${s.location}</p>
<p>Places: ${s.places}</p>

<button class="delete-btn" onclick="deleteSchool(${index})">
Delete
</button>

</div>
`;

});

}

/* DELETE SCHOOL */
function deleteSchool(index){

schools.splice(index,1);

loadSchools();
loadAdmin();

}

/* LOGOUT */
function logout(){

document.getElementById("panel").style.display = "none";
document.getElementById("password").value = "";
document.getElementById("msg").innerHTML = "Logged out successfully!";
document.getElementById("msg").style.color = "blue";

}

/* START */
loadSchools();

</script>

</body>
</html>
